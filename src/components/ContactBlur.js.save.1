/'use client';

import { useState } from 'react';

// Uzbek phone number patterns
const PHONE_PATTERNS = [
    /\+998[\s-]?\d{2}[\s-]?\d{3}[\s-]?\d{2}[\s-]?\d{2}/g, // +998 XX XXX XX XX
    /998\d{9}/g, // 998XXXXXXXXX
    /\d{2}[\s-]?\d{3}[\s-]?\d{2}[\s-]?\d{2}/g, // XX XXX XX XX (local)
];

// Social media patterns
const SOCIAL_PATTERNS = [
    /@[\w._]+/g, // @username (Telegram, Instagram)
    /t\.me\/[\w._]+/gi, // t.me/username
    /instagram\.com\/[\w._]+/gi, // instagram.com/username
];

// Email pattern
const EMAIL_PATTERN = /[\w.-]+@[\w.-]+\.\w+/g;

// Combine all patterns for detection
function detectContactInfo(text) {
    const contacts = [];

    // Detect phones
    PHONE_PATTERNS.forEach(pattern => {
        const matches = text.match(pattern);
        if (matches) {
            matches.forEach(match => contacts.push({ type: 'phone', value: match }));
        }
    });

    // Detect social
    SOCIAL_PATTERNS.forEach(pattern => {
        const matches = text.match(pattern);
        if (matches) {
            matches.forEach(match => contacts.push({ type: 'social', value: match }));
        }
    });

    // Detect emails
    const emailMatches = text.match(EMAIL_PATTERN);
    if (emailMatches) {
        emailMatches.forEach(match => contacts.push({ type: 'email', value: match }));
    }

    return contacts;
}

// Replace contact info with blurred/protected version
export function protectContacts(text, isProtected = true) {
    if (!isProtected) return text;

    let protected = text;

    // Replace phone numbers
    PHONE_PATTERNS.forEach(pattern => {
        protected = protected.replace(pattern, '📞 ••• ••• •• ••');
    });

    // Replace social handles
    SOCIAL_PATTERNS.forEach(pattern => {
        protected = protected.replace(pattern, '📲 @•••••••');
    });

    // Replace emails
    protected = protected.replace(EMAIL_PATTERN, '📧 ••••@••••.••');

    return protected;
}

